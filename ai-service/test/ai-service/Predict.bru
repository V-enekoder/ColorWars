meta {
  name: Predict
  type: http
  seq: 1
}

post {
  url: http://localhost:8000/predict
  body: json
  auth: inherit
}

body:json {
  {
    "board": [
      {
        "points": 10,
        "player": 1
      },
      {
        "points": 5,
        "player": 2
      }
    ],
    "player_id": 1,
    "legal_moves": [
      {
        "row": 5,
        "col": 5
      },
      {
        "row": 4,
        "col": 4
      }
    ],
    "agent_strategy": "random",
    "config": {
      "engine": "python_naive",
      "depth": 5,
      "temperature": 1
    },
    "config_game":{
      "rows": 8,
      "cols": 8,
      "critical_points": 4,
      "num_players": 2,
      "rules": "OnlyOwnOrbs",
      "engine_type": "python_naive"
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
