meta {
  name: Predict
  type: http
  seq: 1
}

post {
  url: http://localhost:8000/predict
  body: json
  auth: inherit
}

body:json {
  {
    "game_config":{
      "rows": 8,
      "cols": 8,
      "critical_points": 4,
      "num_players": 2,
      "rules": "OnlyOwnOrbs"
    },
    "game_state": {
      "board": [
      {
        "points": 10,
        "player": 1
      },
      {
        "points": 5,
        "player": 2
      }
    ],
      "player_id": 1,
      "legal_moves": [
        {
          "row": 5,
          "col": 5
        },
        {
          "row": 4,
          "col": 4
        }
      ]
    },
    "agent_policy":{
      "engine": "mock",
      "strategy": "random"
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
